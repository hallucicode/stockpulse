generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Stocks on your watchlist — the volatile tickers you're tracking
model WatchlistStock {
  id        String   @id @default(cuid())
  symbol    String   @unique
  name      String
  sector    String   @default("Unknown")
  addedAt   DateTime @default(now())

  positions Position[]
  alerts    Alert[]
}

/// A position you own (or owned)
model Position {
  id         String   @id @default(cuid())
  symbol     String
  shares     Float
  buyPrice   Float
  buyDate    DateTime @default(now())
  sellPrice  Float?
  sellDate   DateTime?
  notes      String?

  stock      WatchlistStock @relation(fields: [symbol], references: [symbol])

  /// Computed at query time, but stored for history
  status     String   @default("open") // "open" | "closed"

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Price alerts and signal notifications
model Alert {
  id         String   @id @default(cuid())
  symbol     String
  type       String   // "buy_signal" | "sell_signal" | "price_target" | "stop_loss"
  condition  String   // human-readable: "RSI below 30", "Price above $150"
  threshold  Float?
  triggered  Boolean  @default(false)
  triggeredAt DateTime?

  stock      WatchlistStock @relation(fields: [symbol], references: [symbol])

  createdAt  DateTime @default(now())
}

/// Daily FX-rate cache (Phase 13 — Box 3 helper).
///
/// Sourced from the Frankfurter API (which wraps ECB official daily
/// reference rates). One row per (date, fromCurrency, toCurrency) so
/// any historical-as-of lookup is a cheap indexed read. The fx cron
/// upserts today's rate every day; older rows are kept so peildatum
/// snapshots can later recompute against the rate as it was on that
/// date.
///
/// For v1 we only fetch USD→EUR. The schema is currency-pair-shaped
/// so a future expansion (GBP, CAD, etc.) doesn't require migration.
model FxRate {
  id           String   @id @default(cuid())
  date         DateTime // ECB reference date (UTC midnight)
  fromCurrency String   // "USD"
  toCurrency   String   // "EUR"
  rate         Float    // e.g. 0.9215 means 1 USD = 0.9215 EUR
  fetchedAt    DateTime @default(now())

  @@unique([date, fromCurrency, toCurrency])
  @@index([fromCurrency, toCurrency, date])
}

/// Permanent peildatum / point-in-time portfolio valuation
/// (Phase 13 — Box 3 helper).
///
/// Used for annual aangifte inkomstenbelasting: the Belastingdienst
/// wants total portfolio value on January 1 of the tax year. The user
/// can also snapshot any other date for their own records (year-end,
/// monthly tracking, etc.).
///
/// Append-only: never updated, never pruned. Each row is the full
/// valuation at a moment, so multiple snapshots for the same date are
/// allowed (e.g. one labelled "auto", another labelled "after manual
/// adjustments"). `label` distinguishes them in the UI.
///
/// `perPositionJson` carries the full breakdown — symbol, shares,
/// price (USD), value USD, value EUR — at snapshot time. Forward-
/// compatible (new fields appear in new rows; readers tolerant of
/// missing fields in old rows).
model Box3Snapshot {
  id              String   @id @default(cuid())
  date            DateTime // The peildatum (UTC midnight)
  taxYear         Int      // E.g. 2026 for the 2025 peildatum
  label           String   @default("") // User-supplied free text
  totalValueUsd   Float
  totalValueEur   Float
  usdEurRate      Float    // The rate as of `date`
  perPositionJson String   // JSON-stringified per-position breakdown
  createdAt       DateTime @default(now())

  @@index([taxYear])
  @@index([date])
}

/// Cached price snapshots to avoid hitting APIs too often
model PriceCache {
  id        String   @id @default(cuid())
  symbol    String
  price     Float
  change    Float    @default(0)
  changePct Float    @default(0)
  volume    Float    @default(0)
  high      Float    @default(0)
  low       Float    @default(0)
  fetchedAt DateTime @default(now())

  @@index([symbol, fetchedAt])
}

/// Cached analysis results — updated by background fetcher every 5-10 min
model AnalysisCache {
  id        String   @id @default(cuid())
  symbol    String   @unique
  data      String   // JSON: { symbol, name, sector, analysis }
  fetchedAt DateTime @default(now())

  @@index([fetchedAt])
}

/// Upcoming earnings events (Phase 3). Refreshed daily from a calendar
/// provider (Finnhub free tier in v1). Used to suppress / flag buy signals
/// within N trading days of an earnings announcement.
///
/// `(symbol, date)` is unique because a given company can only report once
/// on any given date — re-fetching just upserts the same row.
model EarningsEvent {
  id          String   @id @default(cuid())
  symbol      String
  date        DateTime // the announcement date (00:00 UTC of the day)
  epsEstimate Float?
  hour        String?  // "bmo" (before market open) | "amc" (after close) | "dmh" (during market hours)
  fetchedAt   DateTime @default(now())

  @@unique([symbol, date])
  @@index([date])
  @@index([symbol])
}

/// Cached diagnosis output per symbol. Avoids re-running the regex
/// classifier when the underlying headlines haven't changed since the last
/// computation — keyed off a hash of the headline list.
///
/// Why cache a pure function? Two reasons:
/// 1. Auditability — `fetchedAt` tells us when the diagnosis last *changed*,
///    not just when the cycle ran. Useful when debugging "why is this stock
///    suddenly tagged FRAUD?".
/// 2. UI stability — cards don't churn category mid-cycle just because we
///    re-classified the same headlines.
model DiagnosisCache {
  id              String   @id @default(cuid())
  symbol          String   @unique
  category        String
  rationale       String
  scoreAdjustment Int
  newsCount       Int
  newsHash        String
  fetchedAt       DateTime @default(now())

  @@index([fetchedAt])
}

/// Daily snapshot of the overall market regime (Phase 6).
/// Computed from SPY (price vs 200-day MA, ADX trend strength) + VIX
/// (level + percentile). One row per refresh — history is preserved so a
/// future /regime page can chart the regime over time, and the
/// background fetcher reads the latest snapshot to weight per-stock
/// signals appropriately.
model RegimeSnapshot {
  id            String   @id @default(cuid())
  regime        String   // "trending_up" | "trending_down" | "ranging" | "high_vol_crisis"
  spyClose      Float
  spy200dma     Float
  adx14         Float
  vixLevel      Float
  vixPercentile Float    // 0-100; current VIX vs trailing 252-day window
  fetchedAt     DateTime @default(now())

  @@index([fetchedAt])
}

/// Daily options-chain snapshot per symbol (Phase 8).
///
/// One row per (symbol, day) so we can compute IV rank as the percentile
/// of today's ATM IV against the trailing N-day window. Yahoo doesn't
/// expose historical IV — we have to build the series ourselves, which
/// is why this table grows over time before the rank signal becomes
/// meaningful (~60 trading days, per OPTIONS_CONFIG.minHistoryDaysForRank).
///
/// All fields are nullable because many tickers don't have liquid options
/// (microcaps, OTC) — we still persist the snapshot so the audit log
/// reflects "we checked".
model OptionsSnapshot {
  id               String   @id @default(cuid())
  symbol           String
  /// ATM implied volatility expressed as a fraction (0.35 = 35%). Null
  /// when no options chain or no near-ATM contracts found.
  atmIV            Float?
  /// Put volume / call volume across the nearest expiry. > 1 = put-heavy.
  putCallRatio     Float?
  /// ATM put IV - ATM call IV. Positive = put-side fear premium ("skew").
  skew             Float?
  /// `unusualCalls`/`unusualPuts` triggered when side volume / open
  /// interest exceeds OPTIONS_CONFIG.unusualVolumeOiRatio.
  unusualCalls     Boolean  @default(false)
  unusualPuts      Boolean  @default(false)
  /// Aggregated volume/OI across the nearest expiry — surfaced for the
  /// UI tooltip + audit trail.
  callVolume       Int      @default(0)
  putVolume        Int      @default(0)
  callOpenInterest Int      @default(0)
  putOpenInterest  Int      @default(0)
  fetchedAt        DateTime @default(now())

  @@index([symbol, fetchedAt])
  @@index([fetchedAt])
}

/// Per-sector ETF trend snapshot (Phase 7.1).
///
/// Daily classification of each sector ETF (XLK, XLF, XLV, ...) into a
/// rotation state ("turning_up" | "trending_up" | "flat" | "trending_down"
/// | "turning_down"). The "turning_up" state — sector recently emerged
/// from an extended downtrend — fires a +1 catalyst on every stock in
/// that sector via Phase 7's catalyst aggregator.
///
/// Only the latest snapshot per sector is needed for live scoring; history
/// is kept (one row per refresh) so a future /sectors page can chart it
/// and Phase 11 backtests can replay sector states deterministically.
model SectorSnapshot {
  id           String   @id @default(cuid())
  sector       String   // app sector key (e.g. "Tech", "Healthcare"); maps to one ETF
  etfSymbol    String   // the ETF used as the sector proxy (XLK, XLV, ...)
  state        String   // "turning_up" | "trending_up" | "flat" | "trending_down" | "turning_down"
  close        Float
  sma200       Float
  // Run lengths used by the classifier — surfaced so the /logs and future
  // /sectors page can show "above 200dma for 6 bars after 47 bars below".
  recentUpBars Int
  priorDownBars Int
  fetchedAt    DateTime @default(now())

  @@index([sector, fetchedAt])
  @@index([fetchedAt])
}

/// Per-symbol Form 4 insider transactions (sourced from Finnhub's
/// `/stock/insider-transactions`, which derives from SEC EDGAR Form 4
/// filings). Used by `insiders.ts` to detect cluster buys — when ≥2
/// distinct insiders buy on the open market within 14 days, that's the
/// strongest single-name signal in finance.
///
/// Refreshed daily; we keep the last 90 days per symbol to bound table size.
model InsiderTransaction {
  id              String   @id @default(cuid())
  symbol          String
  filerName       String
  transactionDate DateTime
  transactionCode String?  // SEC code: "P" (purchase), "S" (sale), "A" (award), etc.
  shareChange     Float    // signed: positive = bought, negative = sold
  price           Float?
  totalValue      Float?   // |shareChange| * price when both known
  fetchedAt       DateTime @default(now())

  @@unique([symbol, filerName, transactionDate, shareChange])
  @@index([symbol, transactionDate])
}

/// Per-symbol analyst rating actions (Finnhub `/stock/upgrade-downgrade`).
/// Used by `analysts.ts` to nudge the score on recent up/downgrades.
model AnalystAction {
  id            String   @id @default(cuid())
  symbol        String
  firm          String
  fromGrade     String?
  toGrade       String?
  action        String   // "up" | "down" | "init" | "main"
  publishedAt   DateTime
  fetchedAt     DateTime @default(now())

  @@unique([symbol, firm, publishedAt, action])
  @@index([symbol, publishedAt])
}

/// FDA drug approvals tied to watchlist tickers (Phase 12).
///
/// Source: openFDA `/drug/drugsfda.json` filtered to recently-approved
/// submissions. The cron pulls every approval in the last
/// `lookbackDays` window, matches each against the Healthcare-sector
/// portion of the watchlist (two-tier matching via `fda.ts`), and
/// persists one row per (symbol, applicationNumber, date).
///
/// Used by Phase 7 catalyst aggregator: when a row exists in the
/// `approvalWindowDays` window for a symbol, the `fda_event` catalyst
/// fires.
///
/// We intentionally store the un-normalised applicantName so an
/// operator looking at /logs can audit "why did we match MRK to this
/// row?" — useful when investigating a false positive.
model FdaEvent {
  id                String   @id @default(cuid())
  symbol            String
  /// FDA application number (e.g. "BLA125514", "NDA208447"). Stable
  /// across resubmissions — the join key for dedup.
  applicationNumber String
  /// "approval" today. Reserved for future "phase3_complete",
  /// "pdufa_date", etc. once we have data sources for those.
  eventType         String
  /// Date of the FDA decision (parsed from openFDA's
  /// `submission_status_date`).
  date              DateTime
  /// Original sponsor / applicant string from openFDA — kept verbatim
  /// for auditability of the watchlist-match.
  applicantName     String
  /// Human-readable summary, e.g. "FDA approval: KEYTRUDA (BLA125514)".
  description       String
  fetchedAt         DateTime @default(now())

  @@unique([symbol, applicationNumber, date])
  @@index([symbol, date])
  @@index([fetchedAt])
}

/// Permanent recommendation timeline (Phase 11).
///
/// Background-fetcher appends one row per (symbol, externally-observable
/// change). `AnalysisCache` only holds the *current* analysis — when a
/// stock moves from BUY → HOLD → BUY over a week, that transition is
/// lost on overwrite. This table is the replay-able record Phase 15
/// (backtest) needs to evaluate "did our signals predict outcomes?", and
/// the same data Phase 18 (decay monitoring) compares live performance
/// against backtest expectations.
///
/// Dedup: insert a row only when the canonical key changes — score,
/// recommendation, regime, present-catalyst set, or quality-veto reason.
/// `analysisHash` is SHA-1 of that canonical key (cheap "has anything
/// changed since the last row for this symbol?" lookup).
///
/// `signalBreakdown` is a full JSON snapshot of the Analysis at the time
/// of writing — minus the `signals[]` UI array. Forward-compatible: when
/// new fields land in `Analysis` they appear in new rows automatically;
/// when Phase 15 reads old rows the missing fields default to undefined.
///
/// Retention: rolling 3-year window (Phase 11), with paper-trade carve-out
/// to be added in Phase 16 (don't prune symbols with open paper trades).
model RecommendationLog {
  id              String   @id @default(cuid())
  symbol          String
  timestamp       DateTime @default(now())
  compositeScore  Int
  recommendation  String   // "STRONG BUY" | "BUY" | "HOLD" | "SELL" | "STRONG SELL"
  regime          String?  // null when regime cron hasn't run yet
  /// JSON-shape version stamp. Always set to the writer's current
  /// `SCHEMA_VERSION` (see `src/lib/recommendation-log.ts`). Bump that
  /// constant when we make a breaking change to the JSON shape that
  /// older readers (Phase 15 backtest replays) can't interpret without
  /// branching logic. Backfilling this onto millions of historical
  /// rows would be an expensive data migration — pinned at write time
  /// instead.
  schemaVersion   Int      @default(1)
  /// SHA-1 of the canonical change-detection key (score, rec, regime,
  /// catalysts.present, qualityVeto.reason). Used by maybeLogRecommendation
  /// to skip writes when nothing externally-observable changed.
  analysisHash    String
  /// Full JSON.stringify(analysis) with the `signals[]` field stripped
  /// (UI-derived; reconstructible from the rest). Read by Phase 15 to
  /// replay a backtest against the exact analysis the system saw at the
  /// time.
  signalBreakdown String

  @@index([symbol, timestamp])
  @@index([timestamp])
}

/// Per-symbol fundamentals snapshot from Finnhub. Refreshed weekly — these
/// numbers don't change daily, and the free tier rate-limits are tight.
///
/// Used by `fundamentals.ts` to apply hard vetoes ("must have earnings",
/// "not microcap", "not over-leveraged") in addition to the existing
/// price-based Phase 2.5 quality gate.
model FundamentalsSnapshot {
  id                  String   @id @default(cuid())
  symbol              String   @unique
  marketCap           Float?   // absolute USD (Finnhub returns millions; we normalise on ingest)
  peRatio             Float?
  debtToEquity        Float?
  freeCashFlowTtm     Float?
  epsTtm              Float?
  revenueGrowthYoy    Float?   // % YoY
  hasReportedEarnings Boolean  @default(false)
  fetchedAt           DateTime @default(now())

  @@index([symbol])
}

/// Per-symbol news items from Finnhub. Used by `diagnosis.ts` to classify
/// *why* a stock dropped (sector selloff, earnings miss, lawsuit, etc.).
///
/// Refreshed daily by the news-source cron (analogous to earnings). We keep
/// only the last ~30 days per symbol to bound table growth.
model NewsItem {
  id          String   @id @default(cuid())
  symbol      String
  externalId  String   // Finnhub's news id (deduplication key)
  headline    String
  summary     String   @default("")
  source      String   @default("")
  url         String   @default("")
  category    String   @default("")  // Finnhub's own category (company | general | ...)
  publishedAt DateTime
  fetchedAt   DateTime @default(now())

  @@unique([symbol, externalId])
  @@index([symbol, publishedAt])
}

/// Persisted application logs — surfaced on `/logs`.
///
/// Not every log entry lands here; we whitelist (1) every warn/error and
/// (2) a small set of "milestone" info events (refresh.done, start, etc.)
/// so the table stays small and readable. See `log-persistence.ts`.
///
/// Cleanup: a periodic prune removes entries older than 30 days. If a future
/// outage floods this table, the read API caps results so the UI stays
/// responsive even before the prune runs.
model LogEntry {
  id        String   @id @default(cuid())
  timestamp DateTime
  level     String   // "debug" | "info" | "warn" | "error"
  component String   // e.g. "earnings", "fetcher", "market-data"
  event     String   // e.g. "refresh.done", "fetch.http-error"
  meta      String?  // JSON-encoded — never queried, only displayed
  createdAt DateTime @default(now())

  @@index([timestamp])
  @@index([level, timestamp])
  @@index([component, timestamp])
}

/// Data-quality audit log — Phase 0 firewall.
/// Every time the validator finds a problem with ingested data, an entry is
/// written here. Used for debugging "why did this stock disappear?", spotting
/// systematic provider issues, and (Phase 1+) auto-removing chronically bad
/// tickers from the watchlist.
model DataQualityLog {
  id        String   @id @default(cuid())
  symbol    String
  type      String   // see data-quality.ts: "stale_data" | "halt_run" | "huge_gap" | "invalid_bar" | "empty_history"
  severity  String   // "low" | "medium" | "high" | "critical"
  detail    String
  loggedAt  DateTime @default(now())
  resolved  Boolean  @default(false)

  @@index([symbol, resolved])
  @@index([loggedAt])
}
