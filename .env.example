# Database — SQLite for local dev (no setup needed)
DATABASE_URL="file:./dev.db"

# Optional: Polygon.io API for real-time data (free tier = 5 calls/min)
# Sign up at https://polygon.io — free tier works fine for personal use
POLYGON_API_KEY=""

# Optional: Alpha Vantage as fallback (free = 25 calls/day)
# Sign up at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=""

# Yahoo Finance (used via yahoo-finance2 npm — no key needed)
# This is the default data source and works out of the box.

# Optional: Ntfy.sh push notifications (free, no signup)
# Pick any topic name, e.g. "stockpulse-myname-alerts"
NTFY_TOPIC=""
